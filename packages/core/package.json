{
  "name": "@mini-ng/core",
  "version": "0.0.3",
  "main": "./dist/core.cjs.js",
  "module": "./dist/core.mjs",
  "types": "./dist/core/index.d.ts",
  "exports": {
    "./core": {
      "import": "./dist/core.mjs",
      "require": "./dist/core.cjs.js",
      "default": "./dist/core.umd.js"
    },
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "esm2022": "./dist/core.mjs",
      "esm": "./dist/core.mjs",
      "default": "./dist/core.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^2.2.48",
    "chai": "^4.1.2",
    "coveralls": "^3.0.0",
    "istanbul": "^0.4.5",
    "mocha": "^10.8.2",
    "rollup": "^4.57.1",
    "rollup-plugin-dts": "^6.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "htmlparser2": "^9.0.0",
    "webpack": "^5.89.0"
  },
  "scripts": {
    "build:types": "tsc -p tsconfig.tsc.json && rollup -c tsc_rollup.config.mjs",
    "build:core": "rollup -c rollup.config.mjs",
    "build": "npm run build:core",
    "prepublishOnly": "npm run build && npm run build:types",
    "dry-run": "npm publish --dry-run",
    "publish-npm": "npm publish --access public",
    "access-public": "npm publish --access public",
    "version": "npm version patch",
    "minor": "npm version minor",
    "major": "npm version major",
    "release": "npm version patch && npm publish",
    "esm-test": "mocha --loader ts-node/esm \\\"test/**/*.ts\\\"",
    "build-all": "npm run build && npm run build:types",
    "test": "mocha -r ts-node/register 'test/**/*.spec.ts'"
  },
  "dependencies": {
    "tslib": "^2.8.1"
  },
  "typings": "./dist/core/index.d.ts",
  "type": "module",
  "keywords": [
    "framework",
    "compiler",
    "component",
    "typescript",
    "javascript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mini-ng/mini-ng"
  },
  "author": {
    "email": "kurtwanger40@gmail.com",
    "name": "Chidume Nnamdi"
  }
}
